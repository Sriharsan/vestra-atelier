# Vestra Atelier — Environment Variables
# Copy this file to .env and fill in real values.

NODE_ENV=development

# Try-on provider: "fashn" | "fal" | "none" (mock/demo mode)
TRYON_PROVIDER=none

# FASHN direct API (when TRYON_PROVIDER=fashn)
# Get a key at https://fashn.ai — starts at ~$0.075/image
# FASHN_API_KEY=fa-...

# fal.ai (when TRYON_PROVIDER=fal)
# Get a key at https://fal.ai
# FAL_KEY=

# Object storage (Cloudflare R2 or S3)
# STORAGE_BUCKET=vestra-uploads
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=

# Analytics (Segment / PostHog)
# ANALYTICS_WRITE_KEY=

# Email / CRM webhook
# CRM_WEBHOOK_URL=

# Error tracking (Sentry)
# SENTRY_DSN=
