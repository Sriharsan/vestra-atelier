# Vestra Atelier — Environment Variables
# Copy this file to .env and fill in real values.

NODE_ENV=development

# Try-on inference API
# TRYON_API_URL=https://api.vestra.ai/v1/tryon
# TRYON_API_KEY=

# Object storage (Cloudflare R2 or S3)
# STORAGE_BUCKET=vestra-uploads
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=

# Analytics (Segment / PostHog)
# ANALYTICS_WRITE_KEY=

# Email / CRM webhook
# CRM_WEBHOOK_URL=

# Error tracking (Sentry)
# SENTRY_DSN=

# Database (if/when needed)
# DATABASE_URL=
