# Vestra Atelier — Environment Variables
# Copy this file to .env and fill in real values.

NODE_ENV=development

# Try-on mode: "demo" (pre-baked/mock) | "live" (calls real provider)
# VITE_TRYON_MODE=demo

# Try-on provider: "fashn" | "fal" | "gradio" | "gemini" | "none" (mock/demo mode)
# If GEMINI_API_KEY is set and TRYON_PROVIDER=none, auto-selects gemini.
TRYON_PROVIDER=none

# Gradio / HuggingFace (when TRYON_PROVIDER=gradio)
# Space URL — defaults to franciszzj/Leffa (supports full-body dress mode)
# TRYON_API_URL=franciszzj/Leffa
# HF token — needed for ZeroGPU spaces
# TRYON_API_KEY=hf_...

# FASHN direct API (when TRYON_PROVIDER=fashn)
# Get a key at https://fashn.ai — starts at ~$0.075/image
# FASHN_API_KEY=fa-...

# fal.ai (when TRYON_PROVIDER=fal)
# Get a key at https://fal.ai
# FAL_KEY=

# Gemini (when TRYON_PROVIDER=gemini, or auto-detected if set)
# Google AI Studio API key — server-side only, never exposed to the client.
# Free tier does not support image generation; requires a billing-enabled key.
# GEMINI_API_KEY=

# Pexels — for seeding demo assets (scripts/seed-assets.ts)
# Free key at https://www.pexels.com/api/
# PEXELS_API_KEY=

# MongoDB — local dev uses localhost; production needs a hosted DB (MongoDB Atlas).
# Demo requests and newsletter subscriptions are stored here.
# If unset, forms still work but submissions are not persisted.
MONGODB_URI=mongodb://localhost:27017/vestra

# Object storage (Cloudflare R2 or S3)
# STORAGE_BUCKET=vestra-uploads
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=

# Analytics (Segment / PostHog)
# ANALYTICS_WRITE_KEY=

# Email / CRM webhook
# CRM_WEBHOOK_URL=

# Error tracking (Sentry)
# SENTRY_DSN=
